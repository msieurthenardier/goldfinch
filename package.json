{
  "name": "goldfinch",
  "version": "0.4.5",
  "description": "A Chromium-based browser with an expandable media panel for viewing, playing, and downloading site media.",
  "main": "src/main/main.js",
  "author": "msieurthenardier <msieurthenardier@gmail.com>",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "dev:debug": "electron . --enable-logging --no-sandbox --remote-debugging-port=9222 --remote-allow-origins=*",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "node --test test/unit/*.test.js",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "a11y": "node scripts/a11y-audit.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "build": {
    "appId": "com.goldfinch.browser",
    "productName": "Goldfinch",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "msieurthenardier <msieurthenardier@gmail.com>"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "axe-core": "^4.12.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
