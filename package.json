{
  "name": "goldfinch",
  "version": "0.7.0",
  "description": "A Chromium-based browser with an expandable media panel for viewing, playing, and downloading site media.",
  "main": "src/main/main.js",
  "author": "msieurthenardier <msieurthenardier@gmail.com>",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "node scripts/dev-launch.mjs --enable-logging",
    "dev:automation": "node scripts/dev-launch.mjs --enable-logging --no-sandbox --automation-dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "node --test test/unit/*.test.js",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "a11y": "node scripts/a11y-audit.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "build": {
    "appId": "com.goldfinch.browser",
    "productName": "Goldfinch",
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "msieurthenardier",
      "repo": "goldfinch"
    },
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "msieurthenardier <msieurthenardier@gmail.com>"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "axe-core": "^4.12.1",
    "electron": "^42.6.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
